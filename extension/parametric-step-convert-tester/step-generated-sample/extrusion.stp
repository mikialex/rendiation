ISO-10303-21;
HEADER;
FILE_DESCRIPTION((''), '2;1');
FILE_NAME('test_extrusion.stp', '2026-05-24', (''), (''), 'Claude', '', '');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 2 10303 214 0 1 1 1 }'));
ENDSEC;
DATA;
/* === Units & context === */
#1 = (LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI., .METRE.));
#2 = DIMENSIONAL_EXPONENTS(0.,0.,0.,0.,0.,0.,0.);
#3 = (NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.));
#4 = PLANE_ANGLE_MEASURE_WITH_UNIT(PLANE_ANGLE_MEASURE(0.0174532925),#3);
#5 = (CONVERSION_BASED_UNIT('DEGREE',#4) NAMED_UNIT(#2) PLANE_ANGLE_UNIT());
#6 = (NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT());
#7 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-06),#1,'','');
#8 = (GEOMETRIC_REPRESENTATION_CONTEXT(3) GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#7)) GLOBAL_UNIT_ASSIGNED_CONTEXT((#5,#6,#1)) REPRESENTATION_CONTEXT('',''));
#9 = APPLICATION_CONTEXT('automotive design');
#10 = APPLICATION_PROTOCOL_DEFINITION('DRAFT_INTERNATIONAL_STANDARD','automotive_design',1998,#9);
#11 = PRODUCT_CONTEXT('3D',#9,'mechanical');
#12 = PRODUCT('TEST_EXTRUSION','TEST_EXTRUSION','',(#11));
#13 = PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('','',#12,.MADE.);
#14 = PRODUCT_DEFINITION_CONTEXT('part definition',#9,'design');
#15 = PRODUCT_DEFINITION('','',#13,#14);
#16 = PRODUCT_DEFINITION_SHAPE('','',#15);
/* === Profile curve: quadratic B-spline, arching up to z=1.5 === */
#20 = CARTESIAN_POINT('',(0.,0.,0.));
#21 = CARTESIAN_POINT('',(1.5,0.,1.5));
#22 = CARTESIAN_POINT('',(3.,0.,0.));
#23 = B_SPLINE_CURVE_WITH_KNOTS('',2,(#20,#21,#22),.UNSPECIFIED.,.F.,.F.,(3,3),(0.,1.),.UNSPECIFIED.);
/* === Extrusion vector: 3 units in Y === */
#24 = DIRECTION('',(0.,1.,0.));
#25 = VECTOR('',#24,3.);
/* === Surface: SURFACE_OF_LINEAR_EXTRUSION === */
#26 = SURFACE_OF_LINEAR_EXTRUSION('',#23,#25);
/* === Vertices === */
#30 = CARTESIAN_POINT('',(0.,0.,0.));
#31 = CARTESIAN_POINT('',(3.,0.,0.));
#32 = CARTESIAN_POINT('',(0.,3.,0.));
#33 = CARTESIAN_POINT('',(3.,3.,0.));
#34 = VERTEX_POINT('',#30);
#35 = VERTEX_POINT('',#31);
#36 = VERTEX_POINT('',#32);
#37 = VERTEX_POINT('',#33);
/* === E1: profile curve at y=0 === */
#40 = EDGE_CURVE('',#34,#35,#23,.T.);
/* === E2: line from (3,0,0) to (3,3,0) === */
#41 = CARTESIAN_POINT('',(3.,0.,0.));
#42 = DIRECTION('',(0.,1.,0.));
#43 = VECTOR('',#42,3.);
#44 = LINE('',#41,#43);
#45 = EDGE_CURVE('',#35,#37,#44,.T.);
/* === E3: profile curve at y=3 (copy of #23 at y=3) === */
#46 = CARTESIAN_POINT('',(0.,3.,0.));
#47 = CARTESIAN_POINT('',(1.5,3.,1.5));
#48 = CARTESIAN_POINT('',(3.,3.,0.));
#49 = B_SPLINE_CURVE_WITH_KNOTS('',2,(#46,#47,#48),.UNSPECIFIED.,.F.,.F.,(3,3),(0.,1.),.UNSPECIFIED.);
#50 = EDGE_CURVE('',#37,#36,#49,.T.);
/* === E4: line from (0,3,0) to (0,0,0) === */
#51 = CARTESIAN_POINT('',(0.,3.,0.));
#52 = DIRECTION('',(0.,-1.,0.));
#53 = VECTOR('',#52,3.);
#54 = LINE('',#51,#53);
#55 = EDGE_CURVE('',#36,#34,#54,.T.);
/* === Loop & face === */
#60 = ORIENTED_EDGE('',*,*,#40,.T.);
#61 = ORIENTED_EDGE('',*,*,#45,.T.);
#62 = ORIENTED_EDGE('',*,*,#50,.F.);
#63 = ORIENTED_EDGE('',*,*,#55,.T.);
#64 = EDGE_LOOP('',(#60,#61,#62,#63));
#65 = FACE_OUTER_BOUND('',#64,.T.);
#66 = ADVANCED_FACE('',(#65),#26,.F.);
/* === Shell & model === */
#70 = CLOSED_SHELL('',(#66));
#71 = MANIFOLD_SOLID_BREP('',#70);
/* === Shape representation === */
#80 = SHAPE_REPRESENTATION('',(#71),#8);
#81 = SHAPE_DEFINITION_REPRESENTATION(#16,#80);
ENDSEC;
END-ISO-10303-21;
